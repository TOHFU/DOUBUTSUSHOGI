{
  "name": "doubutsushogi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "download-figma": "node scripts/download-figma-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:visual:report": "node scripts/generate-visual-report.mjs",
    "test:visual:update": "vitest run --config vitest.visual.config.ts --update",
    "test:visual:docker": "docker run --rm -v \"$PWD:/work\" -v /work/node_modules -w /work -e CI=true mcr.microsoft.com/playwright:v1.61.0-noble bash -lc \"corepack enable && corepack prepare pnpm@9.15.4 --activate && pnpm install --frozen-lockfile && pnpm exec playwright install chromium && pnpm test:visual\"",
    "test:visual:docker:update": "docker run --rm -v \"$PWD:/work\" -v /work/node_modules -w /work -e CI=true mcr.microsoft.com/playwright:v1.61.0-noble bash -lc \"corepack enable && corepack prepare pnpm@9.15.4 --activate && pnpm install --frozen-lockfile && pnpm exec playwright install chromium && pnpm test:visual:update\"",
    "test:e2e": "playwright test",
    "test:all": "pnpm test && pnpm test:visual && pnpm test:e2e"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@serwist/next": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  }
}
